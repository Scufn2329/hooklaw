{
  "name": "hooklaw-monorepo",
  "private": true,
  "description": "HookLaw monorepo — webhook orchestrator with AI agents and MCP tools",
  "packageManager": "pnpm@10.19.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo build",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "dev": "tsx watch packages/cli/src/cli.ts start --verbose",
    "dev:reset": "rm -f hooklaw.db && tsx watch packages/cli/src/cli.ts start --verbose",
    "dev:init": "tsx packages/cli/src/cli.ts init",
    "dev:doctor": "tsx packages/cli/src/cli.ts doctor",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "turbo build && changeset publish"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["better-sqlite3", "esbuild"]
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "turbo": "^2.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  }
}
